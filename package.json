{
  "name": "chinese-poetry-desktop",
  "version": "1.0.0",
  "description": "诗词学习系统桌面应用 - Electron 版本",
  "main": "electron/main.js",
  "author": "",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && npm run dev",
    "electron:dev": "electron .",
    "build:frontend": "cd frontend && npm run build",
    "build:backend": "cd backend && npm install",
    "electron:build": "electron-builder --config electron/electron-builder.json",
    "electron:build:win": "electron-builder --config electron/electron-builder.json --win",
    "electron:build:mac": "electron-builder --config electron/electron-builder.json --mac",
    "electron:build:linux": "electron-builder --config electron/electron-builder.json --linux",
    "postinstall": "electron-builder install-app-deps"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  }
}
