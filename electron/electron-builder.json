{
  "appId": "com.poetry.zhixue",
  "productName": "жҷәйҹөзҒөзҠҖ",
  "copyright": "Copyright В© 2024",
  "directories": {
    "output": "release",
    "buildResources": "electron/build"
  },
  "files": [
    "electron/main.js",
    "backend/**/*",
    "!backend/node_modules/.cache/**/*",
    "!backend/src/**/*",
    "poetry/**/*",
    "nodejs/**/*",
    "package.json"
  ],
  "extraResources": [
    {
      "from": "nodejs",
      "to": "nodejs"
    },
    {
      "from": "poetry",
      "to": "poetry"
    }
  ],
  "asar": false,
  "win": {
    "target": [
      {
        "target": "dir",
        "arch": ["x64"]
      },
      {
        "target": "portable",
        "arch": ["x64"]
      }
    ],
    "icon": "backend/public/run.jpg",
    "artifactName": "${productName}-${version}-${arch}-portable.exe"
  },
  "portable": {
    "artifactName": "${productName}-${version}-portable.exe"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "installerIcon": "backend/public/run.jpg",
    "uninstallerIcon": "backend/public/run.jpg",
    "installerHeaderIcon": "backend/public/run.jpg",
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "жҷәйҹөзҒөзҠҖ"
  }
}
