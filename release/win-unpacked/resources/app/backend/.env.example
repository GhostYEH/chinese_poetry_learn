# ==================== AI API 配置 ====================
# 方式一：硅基流动（推荐，免费额度，支持 OpenAI 兼容接口）
# 在 https://cloud.siliconflow.cn 注册并创建 API Key
SILICONFLOW_API_KEY=

# 方式二：阿里云百炼（dashscope）
# 在 https://bailian.console.aliyun.com 注册并创建 API Key
# ALIYUN_BAILIAN_API_KEY=
# DASHSCOPE_API_KEY=

# 可选：自定义 API 地址（一般不需要改）
# AI_API_URL=https://api.siliconflow.cn/v1/chat/completions

# 可选：自定义模型（硅基流动支持的模型，如 Qwen/Qwen3-8B）
# AI_MODEL=Qwen/Qwen2.5-7B-Instruct

# ==================== 服务器配置 ====================
PORT=3000
HOST=localhost

# ==================== JWT 配置 ====================
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=24h
